@startuml D2a_Infraestrutura_Proxy
!theme materia
title Homelab — D2a: Infraestrutura & Proxy\n(Serviços de gestão e DNS — acesso via LAN ou VPN)

top to bottom direction
skinparam defaultTextAlignment center
skinparam nodesep 40
skinparam ranksep 50

' ── Ponto de entrada (definido em D1) ────────────────────────
card "Nginx Proxy Manager\n[← ver D1 para detalhe de rede]" as npm

' ── Redes Docker ──────────────────────────────────────────────
frame "Docker Networks" {
    frame "homelab_net" as hnet {
        card "Portainer\n[Gestão de containers]" as portainer
        card "Homepage\n[Dashboard pessoal]" as homepage
        card "AdGuard Home\n[Porta host: 53 (DNS)]\n[Bloqueio de anúncios + DNS local]" as adguard
    }
    
    frame "monitor_net" as mnet {
        card "Uptime Kuma\n[Monitor de disponibilidade]" as uptimekuma
        card "Grafana\n[Painéis e Telemetria]" as grafana
    }
    
    frame "immich_net" as inet {
        card "Immich Server\n[Gestão de Fotos]" as immich
    }
}

' ── Proxy passes do NPM ───────────────────────────────────────
npm --> portainer  : "Proxy Pass"
npm --> homepage   : "Proxy Pass"
npm --> uptimekuma : "Proxy Pass"
npm --> grafana    : "Proxy Pass"
npm --> adguard    : "Proxy Pass"
npm --> immich     : "Proxy Pass"

' ── DNS (porta exposta ao host, tráfego vem da LAN diretamente)
cloud "Rede Local (LAN)" as lan
lan --> adguard : "Pedidos DNS\n(porta host 53 UDP/TCP)"

' ── Alertas ───────────────────────────────────────────────────
cloud "Discord (API)" as discord
uptimekuma --> discord : "Webhook\n(Alertas de disponibilidade)"

' ── Referências cruzadas ──────────────────────────────────────
note left of npm
  ← Acesso restrito: LAN ou VPN — ver **D1**
  → Volumes montados em **D4**
  → Stack Completa Observabilidade em **D3**
end note

@enduml
